{
  "title": "Workplace Production Overview",
  "uid": "workplace-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["workplace", "production"],
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(workplace_http_requests_total[5m]))",
          "legendFormat": "requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "API p95 Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "workplace_http_request_p95_duration_ms",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "PostgreSQL Active Connections",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "connections",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Used Memory",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "bytes",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WebSocket Active Connections",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "workplace_websocket_active_connections",
          "legendFormat": "sockets",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" }
}
