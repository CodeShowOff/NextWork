{
  "name": "mobile-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "dev:android": "expo start --dev-client",
    "android:connect": "adb reverse tcp:8081 tcp:8081",
    "android": "expo run:android",
    "android:debug": "expo run:android --variant debug",
    "android:release": "expo run:android --variant release",
    "ios": "expo run:ios",
    "android:apk": "npx eas-cli build --platform android --profile preview",
    "android:apk:debug": "cd android && gradlew.bat assembleDebug",
    "android:apk:release": "cd android && gradlew.bat assembleRelease",
    "ios:ipa": "npx eas-cli build --platform ios --profile preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@shopify/flash-list": "^2.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@workplace/api-contracts": "*",
    "expo": "^55.0.6",
    "expo-image-picker": "~55.0.12",
    "expo-localization": "^55.0.8",
    "expo-secure-store": "^55.0.8",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.8.18",
    "react": "19.2.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "jest": "~29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3"
  }
}
