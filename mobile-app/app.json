{
  "expo": {
    "name": "Workplace",
    "slug": "workplace",
    "scheme": "workplace",
    "version": "0.1.0",
    "icon": "./assets/images/ic_launcher.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.workplace.app"
    },
    "android": {
      "package": "com.workplace.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ic_launcher.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-localization",
      "expo-secure-store"
    ]
  }
}
