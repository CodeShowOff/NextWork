{
  "expo": {
    "name": "Workplace",
    "slug": "workplace",
    "scheme": "workplace",
    "version": "0.1.0",
    "icon": "./assets/images/ic_launcher.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.workplace.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Workplace uses your camera when you join a group live room.",
        "NSMicrophoneUsageDescription": "Workplace uses your microphone when you join a group live room.",
        "NSCalendarsAddUsageDescription": "Workplace adds a group event to your calendar when you choose to export it."
      },
      "bitcode": false
    },
    "android": {
      "package": "com.workplace.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_CALENDAR",
        "WRITE_CALENDAR",
        "POST_NOTIFICATIONS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW",
        "android.permission.WAKE_LOCK",
        "android.permission.BLUETOOTH"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ic_launcher.png",
        "backgroundColor": "#FFFFFF"
      }
    },
    "plugins": [
      "expo-localization",
      "expo-secure-store",
      "expo-document-picker",
      "expo-notifications",
      "expo-calendar",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc"
    ],
    "extra": {
      "eas": {
        "projectId": "897733ef-dbf7-454e-8a3a-b18a34e380c5"
      }
    }
  }
}
