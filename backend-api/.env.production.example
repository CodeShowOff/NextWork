NODE_ENV=production
PORT=4000

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
REDIS_URL=rediss://default:PASSWORD@HOST:6379

# Required auth secrets (minimum 32 chars)
JWT_ACCESS_SECRET=replace-with-random-32-plus-char-secret
JWT_REFRESH_SECRET=replace-with-random-32-plus-char-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional
BREVO_API_KEY=
BREVO_API_BASE_URL=https://api.brevo.com
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=

# Optional URL overrides
INVITE_LINK_BASE_URL=https://workplace.app/invite
POST_SHARE_BASE_URL=https://workplace.app/post
# Required private S3-compatible object storage
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=workplace-production
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

# Required production malware-scanner adapter; unscanned files remain quarantined.
CLAMAV_SCAN_URL=https://scanner.example.com/scan

# LiveKit Cloud credentials
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Optional reliability tuning
LOG_SLOW_REQUEST_MS=1200
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
