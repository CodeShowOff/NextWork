{
  "name": "backend-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "npm run prisma:generate && tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "npm run prisma:generate && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --testPathPatterns src/.*\\.spec\\.ts$",
    "test:integration": "jest --config jest.config.ts --testPathPatterns test/.*\\.int-spec\\.ts$",
    "openapi:export": "node -r ts-node/register/transpile-only src/scripts/export-openapi.ts",
    "docker:up": "docker compose -f ../infrastructure/docker-compose.yml up -d",
    "docker:down": "docker compose -f ../infrastructure/docker-compose.yml down",
    "bootstrap": "npm run prisma:migrate:deploy && npm run prisma:seed",
    "bootstrap:docker": "npm run docker:up && npm run bootstrap",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:sync": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1089.0",
    "@aws-sdk/s3-request-presigner": "^3.1089.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/websockets": "^11.1.17",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "livekit-server-sdk": "^2.17.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.0.3",
    "jest": "^30.3.0",
    "prisma": "^7.5.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  }
}
