NODE_ENV=production
PORT=4000

# Managed service endpoints
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/workplace
REDIS_URL=redis://localhost:6379

# Required auth secrets (use strong random values, minimum 32 chars)
JWT_ACCESS_SECRET=replace-with-32-plus-char-secret
JWT_REFRESH_SECRET=replace-with-32-plus-char-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Optional email provider
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=verified_sender@yourdomain.com
BREVO_SENDER_NAME=Workplace
BREVO_API_BASE_URL=https://api.brevo.com

# Optional URL overrides for generated/public links
INVITE_LINK_BASE_URL=https://workplace.app/invite
POST_SHARE_BASE_URL=https://workplace.app/post
MEDIA_UPLOAD_BASE_URL=https://uploads.workplace.app
MEDIA_PUBLIC_BASE_URL=https://cdn.workplace.app

# Optional reliability tuning
LOG_SLOW_REQUEST_MS=1200
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60