generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(uuid(7)) @db.Uuid
  email        String      @unique
  passwordHash String      @map("password_hash")
  refreshTokenHash String? @map("refresh_token_hash")
  emailVerifiedAt DateTime? @map("email_verified_at")
  emailVerificationTokenHash String? @map("email_verification_token_hash")
  emailVerificationTokenExpiresAt DateTime? @map("email_verification_token_expires_at")
  passwordResetTokenHash String? @map("password_reset_token_hash")
  passwordResetTokenExpiresAt DateTime? @map("password_reset_token_expires_at")
  activeOrganizationId String? @db.Uuid @map("active_organization_id")
  status       String      @default("active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  profile      Profile?
  posts        Post[]
  comments     Comment[] @relation("comment_author")
  deletedComments Comment[] @relation("comment_deleted_by")
  submittedCommentReports CommentReport[] @relation("comment_reporter")
  resolvedCommentReports CommentReport[] @relation("comment_report_resolver")
  sentMessages Message[]   @relation("sent_messages")
  messageReactions MessageReaction[]
  likes        Like[]
  followers    Follow[]    @relation("followee_relation")
  followings   Follow[]    @relation("follower_relation")
  notificationReceipts Notification[] @relation("notification_user")
  notificationActors   Notification[] @relation("notification_actor")
  notificationPreference NotificationPreference?
  deviceTokens DeviceToken[]
  notificationMuteRules NotificationMute[] @relation("notification_mute_owner")
  mutedByNotificationRules NotificationMute[] @relation("notification_mute_target")
  conversationParticipants ConversationParticipant[]
  activeOrganization Organization? @relation("user_active_organization", fields: [activeOrganizationId], references: [id], onDelete: SetNull)
  organizationMemberships OrganizationMember[]
  createdOrganizations Organization[] @relation("organization_creator")
  groupMemberships GroupMember[]
  requestedGroupMemberships GroupMembershipRequest[] @relation("group_membership_requester")
  resolvedGroupMembershipRequests GroupMembershipRequest[] @relation("group_membership_request_resolver")
  sentGroupInvitations GroupInvitation[] @relation("group_invitation_sender")
  receivedGroupInvitations GroupInvitation[] @relation("group_invitation_recipient")
  createdGroups Group[] @relation("group_creator")
  mediaObjects MediaObject[] @relation("media_object_owner")
  uploadedGroupFiles GroupFile[] @relation("group_file_uploader")
  createdGroupAlbums GroupAlbum[] @relation("group_album_creator")
  uploadedGroupAlbumPhotos GroupAlbumPhoto[] @relation("group_album_photo_uploader")
  createdGroupEvents GroupEvent[] @relation("group_event_creator")
  groupEventRsvps GroupEventRsvp[]
  startedLiveSessions LiveSession[] @relation("live_session_starter")
  endedLiveSessions LiveSession[] @relation("live_session_ender")
  generatedInvites InviteLink[] @relation("invite_creator")

  @@map("users")
}

model Profile {
  userId      String   @id @db.Uuid @map("user_id")
  displayName String   @map("display_name")
  bio         String?
  avatarUrl   String?  @map("avatar_url")
  jobTitle    String?  @map("job_title")
  organizationSize String? @map("organization_size")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills ProfileSkill[]

  @@index([displayName])
  @@map("profiles")
}

model Post {
  id         String    @id @default(uuid(7)) @db.Uuid
  authorId   String    @db.Uuid @map("author_id")
  groupId    String?   @db.Uuid @map("group_id")
  content    String
  visibility String    @default("public")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  group    Group?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  media    PostMedia[]
  comments Comment[]
  likes    Like[]

  @@index([authorId, createdAt(sort: Desc)])
  @@index([groupId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("posts")
}

model PostMedia {
  id            String   @id @default(uuid(7)) @db.Uuid
  postId        String   @db.Uuid @map("post_id")
  mediaObjectId String?  @unique @db.Uuid @map("media_object_id")
  mediaUrl      String   @map("media_url")
  mediaType     String   @map("media_type")
  width         Int?
  height        Int?
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  post        Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaObject MediaObject? @relation(fields: [mediaObjectId], references: [id], onDelete: SetNull)

  @@index([postId, sortOrder])
  @@map("post_media")
}

model Comment {
  id              String    @id @default(uuid(7)) @db.Uuid
  postId          String    @db.Uuid @map("post_id")
  authorId        String    @db.Uuid @map("author_id")
  parentCommentId String?   @db.Uuid @map("parent_comment_id")
  deletedById     String?   @db.Uuid @map("deleted_by_id")
  body            String
  createdAt       DateTime  @default(now()) @map("created_at")
  editedAt        DateTime? @map("edited_at")
  deletedAt       DateTime? @map("deleted_at")
  moderationState String    @default("active") @map("moderation_state")

  post          Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User      @relation("comment_author", fields: [authorId], references: [id], onDelete: Cascade)
  deletedBy     User?     @relation("comment_deleted_by", fields: [deletedById], references: [id], onDelete: SetNull)
  parentComment Comment?  @relation("comment_replies", fields: [parentCommentId], references: [id])
  replies       Comment[] @relation("comment_replies")
  reports       CommentReport[]

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([deletedById])
  @@map("comments")
}

model CommentReport {
  id               String    @id @default(uuid(7)) @db.Uuid
  commentId        String    @db.Uuid @map("comment_id")
  reporterId       String    @db.Uuid @map("reporter_id")
  reason           String
  details          String?
  status           String    @default("open")
  resolutionAction String?   @map("resolution_action")
  resolutionNote   String?   @map("resolution_note")
  resolvedById     String?   @db.Uuid @map("resolved_by_id")
  resolvedAt       DateTime? @map("resolved_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  comment    Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporter   User    @relation("comment_reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolvedBy User?   @relation("comment_report_resolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([commentId, status, createdAt(sort: Desc)])
  @@index([reporterId, createdAt(sort: Desc)])
  @@index([resolvedById])
  @@map("comment_reports")
}

model Like {
  id        String   @id @default(uuid(7)) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  postId    String   @db.Uuid @map("post_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@map("likes")
}

model Follow {
  followerId String   @db.Uuid @map("follower_id")
  followeeId String   @db.Uuid @map("followee_id")
  createdAt  DateTime @default(now()) @map("created_at")

  follower User @relation("follower_relation", fields: [followerId], references: [id], onDelete: Cascade)
  followee User @relation("followee_relation", fields: [followeeId], references: [id], onDelete: Cascade)

  @@id([followerId, followeeId])
  @@index([followeeId])
  @@map("follows")
}

model Conversation {
  id        String                    @id @default(uuid(7)) @db.Uuid
  type      String
  createdBy String                    @db.Uuid @map("created_by")
  createdAt DateTime                  @default(now()) @map("created_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId    String   @db.Uuid @map("conversation_id")
  userId            String   @db.Uuid @map("user_id")
  role              String   @default("member")
  joinedAt          DateTime @default(now()) @map("joined_at")
  lastReadMessageId String?  @db.Uuid @map("last_read_message_id")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, conversationId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(uuid(7)) @db.Uuid
  conversationId String    @db.Uuid @map("conversation_id")
  senderId       String    @db.Uuid @map("sender_id")
  body           String
  messageType    String    @default("text") @map("message_type")
  createdAt      DateTime  @default(now()) @map("created_at")
  editedAt       DateTime? @map("edited_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("sent_messages", fields: [senderId], references: [id], onDelete: Cascade)
  attachments  MessageAttachment[]
  reactions    MessageReaction[]

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

model MessageReaction {
  id           String   @id @default(uuid(7)) @db.Uuid
  messageId    String   @db.Uuid @map("message_id")
  userId       String   @db.Uuid @map("user_id")
  reactionType String   @map("reaction_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId, reactionType])
  @@index([userId, createdAt(sort: Desc)])
  @@map("message_reactions")
}

model MessageAttachment {
  id            String   @id @default(uuid(7)) @db.Uuid
  messageId     String   @db.Uuid @map("message_id")
  mediaObjectId String?  @unique @db.Uuid @map("media_object_id")
  attachmentId  String   @db.Uuid @default(uuid(7)) @map("attachment_id")
  mediaType     String   @map("media_type")
  mimeType      String   @map("mime_type")
  fileName      String   @map("file_name")
  fileSizeBytes Int      @map("file_size_bytes")
  storageKey    String   @map("storage_key")
  publicUrl     String   @map("public_url")
  width         Int?
  height        Int?
  durationMs    Int?     @map("duration_ms")
  thumbnailKey  String?  @map("thumbnail_key")
  createdAt     DateTime @default(now()) @map("created_at")

  message     Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mediaObject MediaObject? @relation(fields: [mediaObjectId], references: [id], onDelete: SetNull)

  @@index([messageId, createdAt])
  @@index([attachmentId])
  @@map("message_attachments")
}

model Notification {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  actorId    String?  @db.Uuid @map("actor_id")
  type       String
  entityType String   @map("entity_type")
  entityId   String   @db.Uuid @map("entity_id")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  user  User  @relation("notification_user", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("notification_actor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  userId         String   @id @db.Uuid @map("user_id")
  likeEnabled    Boolean  @default(true) @map("like_enabled")
  commentEnabled Boolean  @default(true) @map("comment_enabled")
  followEnabled  Boolean  @default(true) @map("follow_enabled")
  messageEnabled Boolean  @default(true) @map("message_enabled")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationMute {
  userId      String   @db.Uuid @map("user_id")
  mutedUserId String   @db.Uuid @map("muted_user_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation("notification_mute_owner", fields: [userId], references: [id], onDelete: Cascade)
  mutedUser User @relation("notification_mute_target", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@id([userId, mutedUserId])
  @@index([mutedUserId])
  @@map("notification_mutes")
}

model DeviceToken {
  id         String   @id @default(uuid(7)) @db.Uuid
  userId     String   @db.Uuid @map("user_id")
  platform   String
  token      String
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([platform, token])
  @@index([userId, platform])
  @@index([userId, lastSeenAt(sort: Desc)])
  @@map("device_tokens")
}

model Organization {
  id        String   @id @default(uuid(7)) @db.Uuid
  name      String
  slug      String   @unique
  createdBy String   @db.Uuid @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  createdByUser User @relation("organization_creator", fields: [createdBy], references: [id], onDelete: Cascade)
  members OrganizationMember[]
  groups Group[]
  invites InviteLink[]
  onboardingAudit OrganizationOnboardingAudit?
  activeUsers User[] @relation("user_active_organization")

  @@index([createdBy])
  @@map("organizations")
}

model OrganizationMember {
  organizationId String   @db.Uuid @map("organization_id")
  userId         String   @db.Uuid @map("user_id")
  role           String   @default("member")
  joinedAt       DateTime @default(now()) @map("joined_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Group {
  id             String    @id @default(uuid(7)) @db.Uuid
  organizationId String    @db.Uuid @map("organization_id")
  name           String
  description    String?
  groupType      String    @default("Teams & Projects") @map("group_type")
  groupPrivacy   String    @default("Open") @map("group_privacy")
  photoUrl       String?   @map("photo_url")
  createdBy      String?   @db.Uuid @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User?        @relation("group_creator", fields: [createdBy], references: [id], onDelete: SetNull)
  members      GroupMember[]
  membershipRequests GroupMembershipRequest[]
  invitations GroupInvitation[]
  posts        Post[]
  mediaObjects MediaObject[]
  files GroupFile[]
  albums GroupAlbum[]
  events GroupEvent[]
  liveSessions LiveSession[]

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([name])
  @@map("groups")
}

model GroupMember {
  groupId   String   @db.Uuid @map("group_id")
  userId    String   @db.Uuid @map("user_id")
  role      GroupRole @default(member)
  isFavorite Boolean @default(false) @map("is_favorite")
  lastVisitedAt DateTime? @map("last_visited_at")
  joinedAt  DateTime @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

model OrganizationOnboardingAudit {
  organizationId String   @id @db.Uuid @map("organization_id")
  initializedBy  String   @db.Uuid @map("initialized_by")
  initializedAt  DateTime @default(now()) @map("initialized_at")
  skipped        Boolean  @default(false)
  selectedKeys   String[] @default([]) @map("selected_keys")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_onboarding_audits")
}

enum GroupRole {
  owner
  admin
  member
}

enum GroupMembershipRequestStatus {
  pending
  approved
  declined
  cancelled
}

enum GroupInvitationStatus {
  pending
  accepted
  declined
  revoked
}

enum MediaObjectStatus {
  pending_upload
  scanning
  available
  quarantined
  rejected
  deleted
}

enum GroupEventRsvpStatus {
  going
  maybe
  declined
}

enum LiveSessionStatus {
  active
  ended
}

model GroupMembershipRequest {
  id          String                       @id @default(uuid(7)) @db.Uuid
  groupId     String                       @db.Uuid @map("group_id")
  requesterId String                       @db.Uuid @map("requester_id")
  message     String?
  status      GroupMembershipRequestStatus @default(pending)
  resolvedById String?                     @db.Uuid @map("resolved_by_id")
  resolvedAt  DateTime?                    @map("resolved_at")
  createdAt   DateTime                     @default(now()) @map("created_at")
  updatedAt   DateTime                     @updatedAt @map("updated_at")

  group      Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  requester  User  @relation("group_membership_requester", fields: [requesterId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("group_membership_request_resolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@unique([groupId, requesterId])
  @@index([groupId, status, createdAt(sort: Desc)])
  @@index([requesterId, status])
  @@map("group_membership_requests")
}

model GroupInvitation {
  id          String                @id @default(uuid(7)) @db.Uuid
  groupId     String                @db.Uuid @map("group_id")
  invitedUserId String               @db.Uuid @map("invited_user_id")
  invitedById String                 @db.Uuid @map("invited_by_id")
  status      GroupInvitationStatus @default(pending)
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  group       Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedUser User  @relation("group_invitation_recipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedBy   User  @relation("group_invitation_sender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([groupId, invitedUserId])
  @@index([invitedUserId, status, createdAt(sort: Desc)])
  @@map("group_invitations")
}

model MediaObject {
  id               String            @id @default(uuid(7)) @db.Uuid
  ownerId          String            @db.Uuid @map("owner_id")
  groupId          String?           @db.Uuid @map("group_id")
  storageKey       String            @unique @map("storage_key")
  originalFileName String            @map("original_file_name")
  contentType      String            @map("content_type")
  sizeBytes        Int               @map("size_bytes")
  status           MediaObjectStatus @default(pending_upload)
  scanDetail       String?           @map("scan_detail")
  uploadedAt       DateTime?         @map("uploaded_at")
  availableAt      DateTime?         @map("available_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  owner      User             @relation("media_object_owner", fields: [ownerId], references: [id], onDelete: Cascade)
  group      Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupFile  GroupFile?
  albumPhoto GroupAlbumPhoto?
  messageAttachment MessageAttachment?
  postMedia PostMedia?

  @@index([ownerId, status, createdAt(sort: Desc)])
  @@index([groupId, status, createdAt(sort: Desc)])
  @@map("media_objects")
}

model GroupFile {
  id            String      @id @default(uuid(7)) @db.Uuid
  groupId       String      @db.Uuid @map("group_id")
  mediaObjectId String      @unique @db.Uuid @map("media_object_id")
  uploadedById  String      @db.Uuid @map("uploaded_by_id")
  title         String?
  createdAt     DateTime    @default(now()) @map("created_at")

  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  mediaObject MediaObject @relation(fields: [mediaObjectId], references: [id], onDelete: Cascade)
  uploadedBy  User        @relation("group_file_uploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt(sort: Desc)])
  @@map("group_files")
}

model GroupAlbum {
  id          String   @id @default(uuid(7)) @db.Uuid
  groupId     String   @db.Uuid @map("group_id")
  createdById String   @db.Uuid @map("created_by_id")
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group     Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User              @relation("group_album_creator", fields: [createdById], references: [id], onDelete: Cascade)
  photos    GroupAlbumPhoto[]

  @@index([groupId, createdAt(sort: Desc)])
  @@map("group_albums")
}

model GroupAlbumPhoto {
  id            String      @id @default(uuid(7)) @db.Uuid
  albumId       String      @db.Uuid @map("album_id")
  mediaObjectId String      @unique @db.Uuid @map("media_object_id")
  uploadedById  String      @db.Uuid @map("uploaded_by_id")
  caption       String?
  createdAt     DateTime    @default(now()) @map("created_at")

  album       GroupAlbum  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  mediaObject MediaObject @relation(fields: [mediaObjectId], references: [id], onDelete: Cascade)
  uploadedBy  User        @relation("group_album_photo_uploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([albumId, createdAt(sort: Desc)])
  @@map("group_album_photos")
}

model GroupEvent {
  id          String   @id @default(uuid(7)) @db.Uuid
  groupId     String   @db.Uuid @map("group_id")
  createdById String   @db.Uuid @map("created_by_id")
  title       String
  description String?
  location    String?
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  timezone    String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  group     Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User             @relation("group_event_creator", fields: [createdById], references: [id], onDelete: Cascade)
  rsvps     GroupEventRsvp[]

  @@index([groupId, startsAt])
  @@map("group_events")
}

model GroupEventRsvp {
  eventId   String               @db.Uuid @map("event_id")
  userId    String               @db.Uuid @map("user_id")
  status    GroupEventRsvpStatus
  updatedAt DateTime             @updatedAt @map("updated_at")

  event GroupEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([eventId, status])
  @@map("group_event_rsvps")
}

model LiveSession {
  id          String            @id @default(uuid(7)) @db.Uuid
  groupId     String            @db.Uuid @map("group_id")
  roomName    String            @unique @map("room_name")
  startedById String            @db.Uuid @map("started_by_id")
  endedById   String?           @db.Uuid @map("ended_by_id")
  status      LiveSessionStatus @default(active)
  startedAt   DateTime          @default(now()) @map("started_at")
  endedAt     DateTime?         @map("ended_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  group     Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  startedBy User  @relation("live_session_starter", fields: [startedById], references: [id], onDelete: Cascade)
  endedBy   User? @relation("live_session_ender", fields: [endedById], references: [id], onDelete: SetNull)

  @@index([groupId, status, startedAt(sort: Desc)])
  @@map("live_sessions")
}

model ProfileSkill {
  id             String   @id @default(uuid(7)) @db.Uuid
  profileUserId  String   @db.Uuid @map("profile_user_id")
  name           String
  normalizedName String   @map("normalized_name")
  createdAt      DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileUserId], references: [userId], onDelete: Cascade)

  @@unique([profileUserId, normalizedName])
  @@index([normalizedName])
  @@map("profile_skills")
}

model InviteLink {
  id             String    @id @default(uuid(7)) @db.Uuid
  organizationId String    @db.Uuid @map("organization_id")
  token          String    @unique
  createdBy      String?   @db.Uuid @map("created_by")
  maxUses        Int?      @map("max_uses")
  usedCount      Int       @default(0) @map("used_count")
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User?        @relation("invite_creator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
  @@map("invite_links")
}

